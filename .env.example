# Copia este archivo a .env y completa los valores reales.
# Ver docker-compose.yml para levantar Postgres y Redis en local.

# Servidor
PORT=3000
# development | production — controla el seed de admin y si Swagger se expone (ver README)
NODE_ENV=development

# Base de datos (Postgres)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=smartbox
DATABASE_USER=smartbox
DATABASE_PASSWORD=change-me

# Redis (provisionado en docker-compose.yml; aún sin un módulo que lo use)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=1h

# Mailtrap — correos de recuperación de contraseña y cambio de email.
# Si se omite MAILTRAP_API_KEY, el envío de correos se deshabilita sin romper el arranque.
MAILTRAP_API_KEY=
MAILTRAP_USE_SANDBOX=true
MAILTRAP_INBOX_ID=
MAILTRAP_FROM_EMAIL=noreply@smartbox.com
MAILTRAP_FROM_NAME=Smartbox

# URL del frontend, usada para armar los enlaces de los correos (reset-password, verify-email-change)
FRONTEND_URL=http://localhost:3000

# Orígenes permitidos por CORS, separados por comas (sin espacios extra necesarios, se recortan igual)
CORS_ORIGINS=http://localhost:3000

# Mercado Pago — modelo Marketplace: cada gimnasio conecta su propia cuenta
# vía OAuth (GET /gyms/:id/mercadopago/connect). Estas son las credenciales
# de la APP de SmartBox, no de ningún gimnasio en particular — se sacan del
# panel de desarrolladores: https://www.mercadopago.com.ec/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-change-me
MERCADOPAGO_CLIENT_ID=change-me
MERCADOPAGO_CLIENT_SECRET=change-me
MERCADOPAGO_REDIRECT_URI=http://localhost:3001/mercadopago/oauth/callback

# Secret signature de la app (Tus Integraciones → Webhooks) — verifica la
# firma de POST /memberships/webhook/mercadopago.
MERCADOPAGO_WEBHOOK_SECRET=change-me

# Sentry (E5-03) — opcional. Si se omite, Sentry.init() (src/instrument.ts)
# no envía nada y la app arranca igual; no hace falta cuenta de Sentry para
# desarrollar local.
SENTRY_DSN=
